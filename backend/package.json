{
  "name": "transformbiz-backend",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18 <=22"
  },
  "scripts": {
    "build": "tsc",
    "build:prod": "npm run prisma:generate:prod && tsc",
    "start": "node dist/index.js",
    "start:prod": "prisma db push --schema=prisma/schema.postgres.prisma --skip-generate && node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "test": "jest",
    "seed": "ts-node prisma/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:generate:prod": "prisma generate --schema=prisma/schema.postgres.prisma",
    "prisma:migrate": "prisma migrate dev",
    "db:deploy": "prisma db push --schema=prisma/schema.postgres.prisma --skip-generate",
    "migrate:deploy": "prisma migrate deploy --schema=prisma/schema.postgres.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "docx": "^9.7.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@prisma/adapter-better-sqlite3": "^6.8.2",
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prisma": "^6.8.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
