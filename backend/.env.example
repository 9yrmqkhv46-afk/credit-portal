# ---------------------------------------------------------------------------
# Backend environment variables
# Copy this file to `.env` for local development:  cp .env.example .env
# ---------------------------------------------------------------------------

# Database connection string (read by Prisma).
#   Local development (SQLite, default):
DATABASE_URL="file:./dev.db"
#   Production (PostgreSQL) - example shape, provided automatically by Render:
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# Secret used to sign JWT auth tokens.
# REQUIRED in production. Generate a strong value, e.g.:  openssl rand -base64 32
JWT_SECRET="dev-secret-change-in-production"

# Port the API server listens on. Hosting platforms usually set this for you.
PORT=3001

# Environment mode: development | production | test
NODE_ENV=development

# URL of the frontend, used for the CORS allow-list.
# Local default is http://localhost:3000. In production set this to your
# deployed frontend URL, e.g. https://transformbiz-frontend.onrender.com
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Servicing engine tunables (ALL optional - sensible defaults in
# src/services/servicing.config.ts). Override here to change lending policy
# without a code change.
# ---------------------------------------------------------------------------
# Debt-to-income cap (max borrow = DTI_CAP x gross annual income).
# SERVICING_DTI_CAP=6
# Interest-rate stress buffer added to the actual rate for serviceability.
# SERVICING_STRESS_BUFFER=0.03
# Assumed minimum monthly credit-card repayment as a fraction of the limit.
# SERVICING_CC_REPAYMENT_PCT=0.03
# HEM-style minimum living-expense floors (monthly).
# SERVICING_MIN_EXPENSE_ADULT=1200
# SERVICING_MIN_EXPENSE_CHILD=600
# Shading applied to investment-property rental income (0-1).
# SERVICING_RENTAL_SHADING=0.8

# Optional: external property-data/valuation provider selection (placeholder).
# Used to label the valuation source on properties. NEVER commit real keys.
# PROPERTY_DATA_PROVIDER=manual
# PROPERTY_DATA_API_KEY=

# ---------------------------------------------------------------------------
# Property valuation provider (see src/services/valuation.ts)
# ---------------------------------------------------------------------------
# Selects how property valuations / rental estimates are produced. Default = manual.
#   manual          -> manual entry only (source of truth; DEFAULT)
#   realestate_link -> build a realestate.com.au search/estimate deep link
#                      (NO scraping, NO automated value; broker opens the page)
#   domain_avm      -> Domain Group Rental AVM API. Returns a WEEKLY RENT
#                      estimate that pre-fills the property's "Rent p.w" field.
#   apify           -> generic Apify actor/task connector (value and/or rent).
#   external        -> legacy placeholder (kept for back-compat).
# IMPORTANT: realestate.com.au has no free public valuation API and scraping it
# violates their ToS, so we only ever build a link to their official page. The
# manual entry always remains the value the servicing engine uses.
VALUATION_PROVIDER=manual

# --- Domain Group Rental AVM (VALUATION_PROVIDER=domain_avm) ---
# Get a developer key at https://developer.domain.com.au. NEVER commit a real key.
# DOMAIN_API_KEY=
# Base URL for the Domain API (default below).
# DOMAIN_API_BASE=https://api.domain.com.au
# Header used to send the key. Default X-Api-Key; set to "Authorization" to send
# the key as a Bearer token instead.
# DOMAIN_API_KEY_HEADER=X-Api-Key
# Optional override of the rental-estimate path if Domain versions it.
# DOMAIN_RENTAL_ESTIMATE_PATH=/v1/properties/_rentalEstimate

# --- Apify connector (VALUATION_PROVIDER=apify) ---
# Apify token + the actor (or task) to run. For realestate.com.au valuations the
# default actor is `abotapi~realestate-au-scraper` (used automatically when
# APIFY_ACTOR_ID is unset). The chosen actor should output a value and/or rent
# field; the connector also passes a realestate.com.au searchUrl + startUrls so
# it works across common actor input schemas. NEVER commit a real token.
# APIFY_TOKEN=
# APIFY_ACTOR_ID=abotapi~realestate-au-scraper
# APIFY_TASK_ID=   # use instead of APIFY_ACTOR_ID to run a saved task
# Run mode: sync (default; one call via run-sync-get-dataset-items) or async
# (start a run via /runs, poll status, then read the default dataset).
# APIFY_RUN_MODE=sync

# Legacy: API key for the `external` placeholder provider. Never commit a real key.
# VALUATION_API_KEY=

