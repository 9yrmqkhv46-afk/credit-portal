// This is your Prisma schema file.
// For production, switch the provider to "postgresql" and update DATABASE_URL.
//
// IMPORTANT: This SQLite schema (local dev) MUST stay STRUCTURALLY IDENTICAL to
// ./schema.postgres.prisma (production PostgreSQL). Every model/field change
// must be applied to BOTH files. Only the generator/datasource headers differ.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "queryCompiler"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Enums are not supported in SQLite, so we use String fields with validation at app level.
// Document expected values in comments.

// Role: CLIENT | ADMIN
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("CLIENT")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientProfile ClientProfile?
  loanScenarios LoanScenario[]
  notes         Note[]
  applicationStages ApplicationStage[]
  messages          Message[]
  attachments       Attachment[]
}

// ResidencyStatus: CITIZEN | PERMANENT_RESIDENT | TEMPORARY_VISA
// MaritalStatus: SINGLE | MARRIED | DE_FACTO | DIVORCED | WIDOWED
// EmploymentStatus: FULL_TIME | PART_TIME | CASUAL | SELF_EMPLOYED | UNEMPLOYED | RETIRED
model ClientProfile {
  id                       String   @id @default(uuid())
  userId                   String   @unique
  user                     User     @relation(fields: [userId], references: [id])
  phone                    String?
  address                  String?
  dateOfBirth              DateTime?
  residencyStatus          String   @default("CITIZEN")
  numberOfAdultDependants  Int      @default(0)
  numberOfChildDependants  Int      @default(0)
  privateSchoolingFlag     Boolean  @default(false)
  maritalStatus            String   @default("SINGLE")
  employmentStatus         String   @default("FULL_TIME")
  status                   String   @default("Prospect")

  // --- Profile Centre extended fields (Mandate 4A). All nullable (optional)
  // except sameAsResidential which is a non-nullable Boolean with a default.
  // Zod: nullable columns -> .nullable().optional(); sameAsResidential -> optional only. ---
  legalFirstName      String?
  legalMiddleName     String?
  legalLastName       String?
  preferredName       String?
  gender              String?
  visaSubclass        String?
  mobile              String?
  mailingAddress      String?
  sameAsResidential   Boolean  @default(false)
  employerName        String?
  jobTitle            String?
  employmentStartDate DateTime?
  annualIncome        Float?
  loanPurposePref     String?
  preferredLoanTerm   Int?
  documentChecklist   String?

  // --- Bluehive assessment: extended personal / compliance fields (additive) ---
  borrowerType          String?
  title                 String?
  isFirstHomeBuyer      Boolean   @default(false)
  agesOfChildrenUnder18 String?
  driverLicenceNumber   String?
  driverLicenceExpiry   DateTime?
  passportNumber        String?
  passportExpiry        DateTime?
  countryOfCitizenship  String?
  currentAddressLivingArrangement   String?
  currentAddressDateMovedIn         DateTime?
  previousAddress1                  String?
  previousAddress1DateMovedIn       DateTime?
  previousAddress1LivingArrangement String?
  previousAddress2                  String?
  previousAddress2DateMovedIn       DateTime?
  previousAddress2LivingArrangement String?
  hasDefaultsOrJudgements     Boolean @default(false)
  creditHistoryDetails        String?
  mothersMaidenName           String?
  nearestRelativeName         String?
  nearestRelativeAddress      String?
  nearestRelativePhone        String?
  nearestRelativeRelationship String?
  isCompanyTrustBorrower Boolean   @default(false)
  companyName            String?
  trustName              String?
  companyAddress         String?
  acn                    String?
  abn                    String?
  dateOfIncorporation    DateTime?
  specifiedBeneficiaries String?
  insuranceDetails              String?
  preferredInterestType         String?
  wantsOffsetAccount            Boolean @default(false)
  interestedInCarLoans          Boolean @default(false)
  interestedInEquipmentFinance  Boolean @default(false)
  interestedInCommercialFinance Boolean @default(false)
  interestedInSMSF              Boolean @default(false)
  additionalNotes               String?

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  incomeSources       IncomeSource[]
  existingDebts       ExistingDebt[]
  properties          Property[]
  expenseSummary      ExpenseSummary?
  households          Household[]
  incomeEntries       IncomeEntry[]
  proposedHomeLoans   ProposedHomeLoan[]
  existingHomeLoans   ExistingHomeLoan[]
  personalLiabilities PersonalLiability[]
  livingExpenses      LivingExpenses?
  coBorrower          CoBorrowerProfile?
  employments         Employment[]
  bankAccounts        BankAccount[]
  nonPropertyAssets   NonPropertyAsset[]
  brokerDetails       BrokerCompletedDetails?
}

// Owner: SELF | PARTNER
// Type: SALARY | BONUS | COMMISSION | RENTAL | INVESTMENT | GOVERNMENT | OTHER
// Frequency: WEEKLY | FORTNIGHTLY | MONTHLY | ANNUAL
model IncomeSource {
  id              String   @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id])
  owner           String   @default("SELF")
  type            String
  amount          Float
  frequency       String
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Type: HOME_LOAN | PERSONAL_LOAN | CAR_LOAN | CREDIT_CARD | HECS | OTHER
model ExistingDebt {
  id              String   @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id])
  type            String
  outstandingBalance Float
  monthlyRepayment   Float?
  interestRate       Float?
  creditLimit        Float?
  description        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// Type: OWNER_OCCUPIED | INVESTMENT | RENTAL
// TransactionType: OWNS_WITH_MORTGAGE | OWNS_OUTRIGHT | PURCHASING
model Property {
  id              String   @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id])
  type            String
  address         String
  estimatedValue  Float
  mortgageBalance Float?
  rentalIncome    Float?
  description     String?

  // --- Extended Quickli-style fields (all optional / additive) ---
  postcode                   String?
  purchasePrice              Float?
  purchaseDate               DateTime?
  transactionType            String?
  holidayFlag                Boolean  @default(false)
  eligibleNegativeGearing    Boolean  @default(false)
  rentalIncomeAmount         Float?
  rentalIncomeFrequency      String?
  investmentExpenseAmount    Float?
  investmentExpenseFrequency String?
  valuationSource            String?
  valuationDate              DateTime?
  ownership                  String?
  includeInServicing         Boolean  @default(true)

  // --- Optional inline existing-loan fields for the Property Portfolio table.
  // PREFER deriving loan columns from a linked ExistingHomeLoan
  // (existingHomeLoanId) when present; otherwise these inline fields are used.
  // All nullable -> Zod .nullable().optional().
  existingHomeLoanId         String?
  loanAmount                 Float?
  remainingLoanAmount        Float?
  loanTermRemainingYears     Float?
  currentBank                String?
  loanInterestRate           Float?
  loanMonthlyRepayment       Float?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Frequency: WEEKLY | FORTNIGHTLY | MONTHLY | QUARTERLY | ANNUAL
model ExpenseSummary {
  id              String   @id @default(uuid())
  clientProfileId String   @unique
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id])

  groceries         Float   @default(0)
  groceriesFreq     String  @default("MONTHLY")
  utilities         Float   @default(0)
  utilitiesFreq     String  @default("MONTHLY")
  transport         Float   @default(0)
  transportFreq     String  @default("MONTHLY")
  insurance         Float   @default(0)
  insuranceFreq     String  @default("MONTHLY")
  education         Float   @default(0)
  educationFreq     String  @default("MONTHLY")
  childcare         Float   @default(0)
  childcareFreq     String  @default("MONTHLY")
  entertainment     Float   @default(0)
  entertainmentFreq String  @default("MONTHLY")
  otherExpenses     Float   @default(0)
  otherExpensesFreq String  @default("MONTHLY")

  // --- Expanded living-expense categories (A2). All amounts are OPTIONAL
  // (nullable Float) so a blank UI row is simply omitted; the matching *Freq
  // columns are non-nullable and default to MONTHLY. NOTE: homeLoanRepayment /
  // creditCardRepayment / otherLoanRepayment here are USER-ENTERED expense
  // commitments and are added on top of monthly commitments in the servicing
  // engine; they are intentionally separate from the liabilities module (no
  // double-counting is performed against PersonalLiability rows). ---
  rental                  Float?
  rentalFreq              String  @default("MONTHLY")
  schoolFees              Float?
  schoolFeesFreq          String  @default("MONTHLY")
  homeLoanRepayment       Float?
  homeLoanRepaymentFreq   String  @default("MONTHLY")
  creditCardRepayment     Float?
  creditCardRepaymentFreq String  @default("MONTHLY")
  otherLoanRepayment      Float?
  otherLoanRepaymentFreq  String  @default("MONTHLY")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Purpose: PURCHASE | REFINANCE | INVESTMENT | CONSTRUCTION | EQUITY_RELEASE
// RepaymentType: PI (Principal & Interest) | IO (Interest Only)
model LoanScenario {
  id                    String   @id @default(uuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id])

  householdId           String?
  household             Household? @relation(fields: [householdId], references: [id])

  purpose               String
  repaymentType         String   @default("PI")
  loanTermYears         Int      @default(30)
  interestRate          Float

  // Calculated results
  maxBorrowingCapacity  Float?
  serviceabilityMax     Float?
  dtiMax                Float?
  monthlyRepayment      Float?
  totalMonthlyIncome    Float?
  totalMonthlyExpenses  Float?
  netMonthlySurplus     Float?
  dtiRatio              Float?
  passesServiceability  Boolean?
  passesDti             Boolean?
  messages              String?

  // Rich-text deal summary (free text / lightweight HTML).
  dealSummary           String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Visibility: ADMIN_ONLY | CLIENT_VISIBLE
// LinkedEntityType: PROPERTY | EXISTING_LOAN | PROPOSED_LOAN | null
model Note {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  content          String
  visibility       String   @default("ADMIN_ONLY")
  authorId         String
  linkedEntityType String?
  linkedEntityId   String?
  // --- Admin Remarks Log (Mandate 4B). tags = comma-separated tag keys
  // (nullable -> Zod .nullable().optional()); pinned = non-nullable Boolean. ---
  tags             String?
  pinned           Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ===========================================================================
// Applicant & Household
// ===========================================================================

model Household {
  id              String   @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id])
  name            String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  applicants    Applicant[]
  loanScenarios LoanScenario[]
}

// Relationship: PRIMARY | SPOUSE | PARTNER | OTHER
model Applicant {
  id              String   @id @default(uuid())
  householdId     String
  household       Household @relation(fields: [householdId], references: [id])
  name            String
  relationship    String?
  postcode        String?
  dependantsCount Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  dependants    Dependant[]
  incomeEntries IncomeEntry[]
}

model Dependant {
  id          String   @id @default(uuid())
  applicantId String
  applicant   Applicant @relation(fields: [applicantId], references: [id])
  age         Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ===========================================================================
// Income (Quickli-style detailed income entries)
// ===========================================================================
// Category (MAIN): BASE_SALARY_PAYG | SECOND_PAYG | CASUAL | COMMISSION |
//   OVERTIME | ESSENTIAL_OVERTIME | ALLOWANCES | BONUS_RECENT | BONUS_PREVIOUS |
//   FOREIGN_PAYG | NET_FOREIGN | INVESTMENT | INTEREST | SUPER_ANNUITY | CARERS |
//   GOVERNMENT_PENSION | COMPANY_CAR | CHILD_MAINTENANCE | OTHER_TAXED |
//   OTHER_TAX_FREE | FAMILY_TAX_A | FAMILY_TAX_B | PARENTING_PAYMENT
// EmploymentType: FULL_TIME_PERMANENT | PART_TIME | CASUAL | CONTRACT
model IncomeEntry {
  id              String   @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id])
  applicantId     String?
  applicant       Applicant? @relation(fields: [applicantId], references: [id])

  // Owner of this income entry: SELF | PARTNER (nullable, defaults SELF). The
  // Partner option is surfaced in the UI when the profile maritalStatus is
  // MARRIED or DE_FACTO; the servicing engine sums all entries regardless.
  owner           String?  @default("SELF")
  category        String
  amount          Float
  frequency       String   @default("ANNUAL")
  shadingOverride Float?

  // --- YTD detail block (per job) ---
  jobNumber           Int?
  employer            String?
  employmentType      String?
  industry            String?
  startDate           DateTime?
  payDate             DateTime?
  payslipEndDate      DateTime?
  payFrequency        String?
  baseSalaryPerPeriod Float?
  grossYtd            Float?
  lessBonus           Float?
  nonBaseToAllocate   Float?
  nonBaseToOmit       Float?
  useDetailedYtd      Boolean  @default(false)
  useSecondPayslip    Boolean  @default(false)

  // --- HECS / HELP ---
  hecsFlag        Boolean  @default(false)
  hecsAmount      Float?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ===========================================================================
// Proposed & Existing Home Loans
// ===========================================================================

model ProposedHomeLoan {
  id              String   @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id])

  productType        String?
  investmentFlag     Boolean  @default(false)
  loanAmount         Float
  termYears          Int      @default(30)
  ioTermYears        Int      @default(0)
  interestRate       Float?
  lvr                Float?
  overrideRate       Boolean  @default(false)
  securityLinks      Int      @default(0)
  ownership          String?
  includeInServicing Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ExistingHomeLoan {
  id              String   @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id])

  locFlag            Boolean  @default(false)
  investmentFlag     Boolean  @default(false)
  loanAmount         Float
  interestRate       Float
  termYears          Int      @default(30)
  ioTermYears        Int      @default(0)
  monthlyRepayment   Float?
  lender             String?
  securityLinks      Int      @default(0)
  ownership          String?
  includeInServicing Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ===========================================================================
// Personal Liabilities
// ===========================================================================
// Type: CREDIT_CARD | CAR_LOAN | PERSONAL_LOAN | HECS | OTHER
model PersonalLiability {
  id              String   @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id])

  type               String
  limit              Float?
  interestRate       Float?
  remainingTermYears Float?
  repaymentAmount    Float?
  includeInServicing Boolean  @default(true)
  ownership          String?
  ownershipPercent   Float?
  lender             String?
  description        String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ===========================================================================
// Living Expenses (extended, HEM-style)
// ===========================================================================
model LivingExpenses {
  id              String   @id @default(uuid())
  clientProfileId String   @unique
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id])

  basicExpenseAmount    Float   @default(0)
  basicExpenseFrequency String  @default("MONTHLY")

  // Additional declared categories (all optional)
  propertyTax             Float?
  strataBodyCorp          Float?
  privateSchoolFees       Float?
  childSupportMaintenance Float?
  privateHealthInsurance  Float?
  lifeInsurance           Float?
  secondaryResidenceCosts Float?
  otherNonHem             Float?

  useNotionalRent Boolean  @default(false)
  rentBoardAmount Float?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}


// ===========================================================================
// Loan Application Status Timeline (Mandate 2)
// ===========================================================================
// status: completed | active | upcoming | skipped
// One row per stage per client (18 stages seeded idempotently on first request).
model ApplicationStage {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  key         String
  label       String
  group       String
  orderIndex  Int
  status      String    @default("upcoming")
  completedAt DateTime?
  dueDate     DateTime?
  note        String?
  hasDate     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ===========================================================================
// Messaging Hub (Mandate 4C)
// ===========================================================================
// senderRole: CLIENT | ADMIN | SYSTEM
// type: text | stage_update | document_request | borrowing_summary | meeting_request
// status: sent | delivered | read
// cardData / reactions: JSON-encoded strings (nullable)
model Message {
  id           String   @id @default(uuid())
  clientUserId String
  clientUser   User     @relation(fields: [clientUserId], references: [id])
  senderRole   String
  body         String?
  type         String   @default("text")
  cardData     String?
  status       String   @default("sent")
  resolved     Boolean  @default(false)
  flagged      Boolean  @default(false)
  reactions    String?
  createdAt    DateTime @default(now())
}


// ===========================================================================
// Attachments (document uploads + messaging attachments)
// ===========================================================================
// Files are stored IN THE DATABASE as base64 (dataBase64) so uploads survive
// Render's ephemeral disk + work against Neon Postgres. An attachment may be
// linked to a chat Message (messageId) and/or a Profile Document Checklist
// item (profileDocumentKey). status: Uploaded | Verified.
model Attachment {
  id                 String   @id @default(uuid())
  ownerUserId        String
  owner              User     @relation(fields: [ownerUserId], references: [id])
  messageId          String?
  profileDocumentKey String?
  filename           String
  mimeType           String
  sizeBytes          Int
  dataBase64         String
  status             String   @default("Uploaded")
  createdAt          DateTime @default(now())
}



// ===========================================================================
// 2026 Bank Policy Library (versioned + audited)
// ===========================================================================
// Each row is one immutable policy version for a bank. The full BankPolicy is
// stored as JSON (policyJson) so the engine/ranking run without hard-coding.
// One active version per brandCode is used for new calculations.
model BankPolicyVersion {
  id             String   @id @default(uuid())
  brandCode      String
  bankName       String
  policyVersion  String
  isActive       Boolean  @default(false)
  effectiveFrom  DateTime @default(now())
  notes          String?
  policyJson     String
  createdByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// action: SEED | CREATE_VERSION | EDIT | ACTIVATE | CLONE
model BankPolicyAudit {
  id         String   @id @default(uuid())
  brandCode  String
  action     String
  detail     String?
  actorEmail String?
  createdAt  DateTime @default(now())
}



// ===========================================================================
// Bluehive assessment: Co-Borrower, Employment history, Assets, Broker details
// ===========================================================================
model CoBorrowerProfile {
  id              String        @id @default(uuid())
  clientProfileId String        @unique
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id])

  relationshipToBorrower1 String?
  borrowerType            String?
  title                   String?
  firstName               String?
  middleName              String?
  lastName                String?
  dateOfBirth             DateTime?
  maritalStatus           String?
  numberOfChildrenUnder18 Int      @default(0)
  agesOfChildrenUnder18   String?
  currentAddress                  String?
  currentAddressDateMovedIn       DateTime?
  currentAddressLivingArrangement String?
  homePhone               String?
  mobilePhone             String?
  email                   String?
  driverLicenceNumber  String?
  driverLicenceExpiry  DateTime?
  passportNumber       String?
  passportExpiry       DateTime?
  countryOfCitizenship String?
  residencyStatus      String?
  visaSubclass         String?
  previousAddress1                  String?
  previousAddress1DateMovedIn       DateTime?
  previousAddress1LivingArrangement String?
  previousAddress2                  String?
  previousAddress2DateMovedIn       DateTime?
  previousAddress2LivingArrangement String?
  hasDefaultsOrJudgements     Boolean @default(false)
  creditHistoryDetails        String?
  mothersMaidenName           String?
  nearestRelativeName         String?
  nearestRelativeAddress      String?
  nearestRelativePhone        String?
  nearestRelativeRelationship String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employment {
  id              String        @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id])

  owner               String   @default("SELF")
  sequence            Int      @default(1)
  isSelfEmployed      Boolean  @default(false)
  abn                 String?
  employerName        String?
  employerAddress     String?
  employerPhone       String?
  contactName         String?
  employmentType      String?
  jobTitle            String?
  dateStarted         DateTime?
  dateFinished        DateTime?
  annualSalaryExSuper Float?
  includesBonus       Boolean  @default(false)
  includesCommission  Boolean  @default(false)
  includesOvertime    Boolean  @default(false)
  includesAllowances  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BankAccount {
  id              String        @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id])

  institution    String?
  accountNumber  String?
  balance        Float?
  accountHolders String?
  accountType    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NonPropertyAsset {
  id              String        @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id])

  assetType   String
  description String?
  value       Float?
  owner       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BrokerCompletedDetails {
  id              String        @id @default(uuid())
  clientProfileId String        @unique
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id])

  conveyancerName    String?
  conveyancerAddress String?
  conveyancerPhone   String?
  conveyancerEmail   String?
  lenderSelected     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
