# ---------------------------------------------------------------------------
# Frontend environment variables
# Copy this file to `.env.local` for local development:
#   cp .env.example .env.local
# ---------------------------------------------------------------------------

# Base URL of the backend API (must include the /api suffix).
# NOTE: NEXT_PUBLIC_ variables are inlined at BUILD time, so this must be set
# before/at build for production deployments.
#
#   Local development:
NEXT_PUBLIC_API_URL=http://localhost:3001/api
#   Production example (point at your deployed backend):
#   NEXT_PUBLIC_API_URL=https://transformbiz-backend.onrender.com/api
